# Test environment variables. Copy to `.env.test` and fill in real values.
# `.env.test` is gitignored; do NOT commit it.
#
# The pytest session-scoped conftest at the repo root calls
# load_dotenv(".env.test"), and per-link test files also call load_dotenv(),
# so anything set here is available to tests.

# ─── Service credentials (real-API tests skip when unset) ────────────────────
CONSERVER_API_TOKEN=fake-token
OPENAI_API_KEY=sk-…
DEEPGRAM_KEY=…
GROQ_API_KEY=gsk_…
HUGGINGFACE_API_KEY=hf_…

# ─── Per-link real-API test gates ────────────────────────────────────────────
# Each gate is independent. Without the gate set, tests fall back to mocks.
RUN_OPENAI_ANALYZE_TESTS=1
RUN_OPENAI_ANALYZE_LABEL_TESTS=1
RUN_OPENAI_CHECK_TAG_TESTS=1

# ─── Feature flags ───────────────────────────────────────────────────────────
# agent_session recording (draft-howe-vcon-agent-session). Off by default;
# set to a truthy value (`true`, `1`, `yes`, `on`) to enable in tests.
CONSERVER_RECORD_AGENT_SESSION=true
